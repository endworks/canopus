{
  "name": "@canopus/twitter-downloader",
  "version": "0.2.0",
  "description": "just get media urls from tweets without bullshit",
  "author": {
    "name": "ender-null",
    "email": "endernull@icloud.com",
    "url": "https://github.com/ender-null"
  },
  "homepage": "https://github.com/endworks/canopus-twitter-downloader",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/endworks/canopus-twitter-downloader.git"
  },
  "bugs": {
    "url": "https://github.com/endworks/canopus-twitter-downloader/issues"
  },
  "license": "MIT",
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@canopus/nest": "workspace:*",
    "@canopus/shared": "workspace:*",
    "@nestjs/cache-manager": "^3.1.3",
    "@nestjs/common": "^11.1.27",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.27",
    "@nestjs/microservices": "^11.1.27",
    "@nestjs/platform-express": "^11.1.27",
    "cache-manager": "^7.2.8",
    "nestjs-pino": "^4.6.1",
    "pino": "^10.3.1",
    "reflect-metadata": "^0.2.2",
    "rimraf": "^6.1.3",
    "rxjs": "^7.8.2",
    "twitter-api-v2": "^1.29.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.23",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.27",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.0.1",
    "@types/supertest": "^7.2.0",
    "jest": "^30.4.2",
    "pino-pretty": "^13.1.3",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-loader": "^9.6.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  },
  "files": [
    "dist"
  ]
}
